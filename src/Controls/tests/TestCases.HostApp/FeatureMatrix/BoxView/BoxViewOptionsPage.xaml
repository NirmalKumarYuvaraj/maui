<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Maui.Controls.Sample.BoxViewOptionsPage"
             xmlns:local="clr-namespace:Maui.Controls.Sample"
             Title="BoxViewOptionsPage">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Apply"
                     Clicked="ApplyButton_Clicked"
                     AutomationId="Apply"/>
        <ToolbarItem Text="Reset"
                     Command="{Binding ResetCommand}"
                     AutomationId="ResetButton"/>
    </ContentPage.ToolbarItems>

    <StackLayout Grid.Row="1"
                 Padding="20"
                 Spacing="10">

        <Label FontAttributes="Bold"
               AutomationId="CornerRadiusLabel"
               Text="Corner Radius"/>
        <local:UITestEntry x:Name="CornerRadiusEntry"
                           AutomationId="CornerRadiusEntry"
                           Placeholder="e.g. 20 or 10,20,30,40"
                           IsCursorVisible="False"
                           Text="{Binding CornerRadiusEntryText, Mode=TwoWay}"
                           TextChanged="OnCornerRadiusEntryChanged"/>

        <Label FontAttributes="Bold"
               Text="Box Color"/>
        <StackLayout Orientation="Horizontal"
                     Spacing="10">
            <RadioButton Content="Red"
                         Value="Red"
                         GroupName="Colors"
                         AutomationId="RedRadioButton"
                         IsChecked="{Binding IsRedChecked, Mode=TwoWay}"/>
            <RadioButton Content="Blue"
                         Value="Blue"
                         GroupName="Colors"
                         AutomationId="BlueRadioButton"
                         IsChecked="{Binding IsBlueChecked, Mode=TwoWay}"/>
            <RadioButton Content="Green"
                         Value="Green"
                         GroupName="Colors"
                         AutomationId="GreenRadioButton"
                         IsChecked="{Binding IsGreenChecked, Mode=TwoWay}"/>


        </StackLayout>
    </StackLayout>
</ContentPage>